{
  "name": "opsctl-docs",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "next build",
    "dev": "next dev",
    "preview": "bunx --bun wrangler pages dev out",
    "pages:deploy": "bunx --bun wrangler pages deploy out --project-name ai-deploy --branch main",
    "types:check": "rm -rf .next && fumadocs-mdx && next typegen && tsc --noEmit",
    "postinstall": "fumadocs-mdx",
    "lint": "eslint",
    "content:check": "bun ./scripts/check-content-parity.ts",
    "check": "bun run content:check && bun run lint && bun run types:check && bun run build"
  },
  "dependencies": {
    "@fontsource/ibm-plex-mono": "5.2.7",
    "@fontsource/ibm-plex-sans": "5.2.8",
    "@fumadocs/language": "^0.2.0",
    "@orama/orama": "3.1.18",
    "@orama/tokenizers": "3.1.18",
    "cnfast": "^0.0.8",
    "fumadocs-core": "16.11.2",
    "fumadocs-mdx": "15.1.0",
    "fumadocs-ui": "npm:@fumadocs/base-ui@16.11.2",
    "lucide-react": "^1.23.0",
    "next": "16.2.10",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.2",
    "@types/mdx": "^2.0.14",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.39.4",
    "eslint-config-next": "16.2.10",
    "postcss": "^8.5.16",
    "tailwindcss": "^4.3.2",
    "typescript": "^6.0.3",
    "wrangler": "4.110.0"
  }
}
