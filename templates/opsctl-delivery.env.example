# Non-secret configuration for templates/opsctl-git-push-deliver.sh.
# Keep actual application secrets in the separately permissioned service env file.
OPSCTL_REGISTRY=/srv/server-registry
OPSCTL_STATE_DIR=/var/lib/opsctl
OPSCTL_DELIVERY_PROJECT_ROOT=/srv/projects/example
OPSCTL_DELIVERY_SERVICE_ID=example
OPSCTL_DELIVERY_RUNTIME_USER=deploy
OPSCTL_DELIVERY_BRANCH=main
OPSCTL_DELIVERY_MODE=execute
OPSCTL_DELIVERY_PROFILE=auto
OPSCTL_DELIVERY_TLS=automatic
OPSCTL_DELIVERY_PORT=3000
OPSCTL_DELIVERY_DOMAIN=example.com
OPSCTL_DELIVERY_ENV_FILE=/etc/opsctl/services/example.env
# OPSCTL_DELIVERY_SYSTEMD_UNIT=example.service
# OPSCTL_DELIVERY_STATIC_DESTINATION=/srv/www/example
