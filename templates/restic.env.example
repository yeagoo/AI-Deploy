# Copy this file to /etc/opsctl/restic.env and set mode 0600.
# Do not commit or paste the real file contents into chat or issue trackers.
#
# Example:
#   sudo install -d -m 0750 -o root -g opsctl /etc/opsctl
#   sudo install -m 0600 -o root -g opsctl templates/restic.env.example /etc/opsctl/restic.env
#   sudo editor /etc/opsctl/restic.env

# Restic repository URL. For S3-compatible storage this usually looks like:
#   s3:https://<endpoint>/<bucket>/<prefix>
RESTIC_REPOSITORY=s3:https://s3.example.com/example-bucket/opsctl

# Restic repository encryption password. Store the real value only in
# /etc/opsctl/restic.env or another operator-managed secret file.
RESTIC_PASSWORD=change-me

# S3-compatible credentials used by restic.
AWS_ACCESS_KEY_ID=change-me
AWS_SECRET_ACCESS_KEY=change-me

# Optional for some S3-compatible providers.
AWS_DEFAULT_REGION=us-west-2

# Extra command lookup paths for controlled project adapters.
# This server uses Bun under /home/ivmm/.bun/bin.
OPSCTL_EXTRA_PATHS=/home/ivmm/.bun/bin

# Optional images used only for isolated restore-drill database import checks.
# Use a plain postgres image when no extensions are required. Projects using
# pgvector should use pgvector/pgvector:pg18-trixie for import drills.
OPSCTL_RESTORE_POSTGRES_IMAGE=postgres:18-alpine
OPSCTL_RESTORE_MYSQL_IMAGE=mysql:8.0
OPSCTL_RESTORE_MARIADB_IMAGE=mariadb:11
